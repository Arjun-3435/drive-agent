# ── Groq ──────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here

# ── Google Drive ──────────────────────────────────
GOOGLE_DRIVE_FOLDER_ID=your_google_drive_folder_id_here

# LOCAL: path to your downloaded service account JSON
SERVICE_ACCOUNT_PATH=credentials/service_account.json

# CLOUD (Railway/Render): base64-encoded JSON content
SERVICE_ACCOUNT_B64=

# ── App ───────────────────────────────────────────
APP_ENV=development